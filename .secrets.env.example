# Copy to .secrets.env (gitignored) and fill in, then: make secrets
# Every value here becomes a GitHub Actions secret on noahbaxter/_plugins.
# Blank values are skipped, so you can provision in stages.

# --- Apple signing (6) -------------------------------------------------------
# EASIEST path: skip these here and run Noah's helper, which sets all six directly:
#   ~/.claude/scripts/setup-apple-signing.sh noahbaxter/_plugins
# It reads certs from ~/.claude/secrets/ and the password from Bitwarden "Apple Signing".
# Team ID is KUP5WU7WPC. If you do fill them here, don't also run the helper (no double-set).
#
# base64 of the Developer ID Application .p12:
APPLE_CERTIFICATE_APPLICATION=
# base64 of the Developer ID Installer .p12:
APPLE_CERTIFICATE_INSTALLER=
# password protecting both .p12 files:
APPLE_CERTIFICATE_PASSWORD=
# Apple ID email used for notarization:
APPLE_ID=
# Apple Developer Team ID:
APPLE_TEAM_ID=KUP5WU7WPC
# app-specific password for notarytool:
APPLE_APP_PASSWORD=

# --- Cloudflare R2 (2) -------------------------------------------------------
# Cloudflare dashboard -> R2 -> Manage R2 API Tokens -> create a token with
# Object Read & Write on the plugin buckets. Yields an S3-style key id + secret.
# One token spanning all buckets is fine (pewpew + guillotine already share one).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Plugin + webplug-ui read access (1) ------------------------------------
# ONE fine-grained PAT: github.com/settings/tokens?type=beta
# Permissions: Contents: Read-only.
# Repository access: you MUST explicitly select EVERY plugin repo AND webplug-ui.
# Fine-grained tokens default to "Public repositories" only; if a repo isn't
# selected you get a 404 "Repository not found" (not an auth error).
# Used for: private submodule checkout + the bun webplug-ui clone rewrite.
PLUGINS_CI_TOKEN=

# --- Site deploy for the update manifest (1) --------------------------------
# Fine-grained PAT with Contents: Read and Write on noahbaxter/dichoticstudios.com.
# The release job commits static/updates/<plugin>.json there; Cloudflare Pages
# auto-deploys. Leave blank to skip manifest publishing.
SITE_DEPLOY_TOKEN=
