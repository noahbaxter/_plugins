# Copy to .secrets.env (gitignored) and fill in, then: make secrets
# Every value here becomes a GitHub Actions secret on noahbaxter/_plugins.
# Blank values are skipped, so you can provision in stages.

# --- Apple signing (6) -------------------------------------------------------
# EASIEST path: skip these here and run Noah's helper, which sets all six directly:
#   ~/.claude/scripts/setup-apple-signing.sh noahbaxter/_plugins
# It reads certs from ~/.claude/secrets/ and the password from Bitwarden "Apple Signing".
# Team ID is KUP5WU7WPC. If you do fill them here, don't also run the helper (no double-set).
#
# base64 of the Developer ID Application .p12:
APPLE_CERTIFICATE_APPLICATION=
# base64 of the Developer ID Installer .p12:
APPLE_CERTIFICATE_INSTALLER=
# password protecting both .p12 files:
APPLE_CERTIFICATE_PASSWORD=
# Apple ID email used for notarization:
APPLE_ID=
# Apple Developer Team ID:
APPLE_TEAM_ID=KUP5WU7WPC
# app-specific password for notarytool:
APPLE_APP_PASSWORD=

# --- Cloudflare R2 (2) -------------------------------------------------------
# Cloudflare dashboard -> R2 -> Manage R2 API Tokens -> create a token with
# Object Read & Write on the plugin buckets. Yields an S3-style key id + secret.
# One token spanning all buckets is fine (pewpew + guillotine already share one).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Plugin + webplug-ui access (1) -----------------------------------------
# ONE fine-grained PAT: github.com/settings/tokens?type=beta
# Permissions: Contents: read/write  AND  Actions: read/write.
#   - Contents read : private submodule checkout + the bun webplug-ui clone + read
#                     each plugin's VERSION / CHANGELOG.md.
#   - Contents write: cut the GitHub release on the PLUGIN repo (attach binaries
#                     for non-gated plugins).
#   - Actions write : lets the SAME token, set as HUB_DISPATCH_TOKEN on each plugin
#                     repo, fire this hub's release.yml from a push/tag.
# Repository access: you MUST explicitly select EVERY plugin repo AND webplug-ui
# AND _plugins. Fine-grained tokens default to "Public repositories" only; if a
# repo isn't selected you get a 404 "Repository not found" (not an auth error).
#
# Distribute the same PAT string two ways (scripts/secrets-sync.sh sets the hub one):
#   PLUGINS_CI_TOKEN   here (on _plugins)          -> checkout + release + changelog
#   HUB_DISPATCH_TOKEN on each plugin repo         -> `gh secret set HUB_DISPATCH_TOKEN -R noahbaxter/<plugin>`
PLUGINS_CI_TOKEN=

# --- Site deploy for changelog + update manifest (1) ------------------------
# NOT a PAT — an SSH deploy key with write access to noahbaxter/dichoticstudios.com.
# The publish job commits static/changelogs/<plugin>.json + static/updates/<plugin>.json
# there; Cloudflare Pages auto-deploys. Generate + install once:
#   ssh-keygen -t ed25519 -f site_deploy -N '' -C 'plugins-release-manifest'
#   gh repo deploy-key add site_deploy.pub -R noahbaxter/dichoticstudios.com --title '_plugins release manifest' --allow-write
#   gh secret set SITE_DEPLOY_SSH_KEY -R noahbaxter/_plugins < site_deploy
# Paste the PRIVATE key (multi-line) here, or set it directly with the gh command above.
SITE_DEPLOY_SSH_KEY=
